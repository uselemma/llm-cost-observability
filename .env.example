LITELLM_KEYS="sk-...:dev,sk-...:prod"
VERCEL_AI_GATEWAY_API_KEY=
FIREWORKS_AI_API_KEY=
CLOUDFLARE_AI_GATEWAY_COMPAT_BASE_URL=
CLOUDFLARE_AI_GATEWAY_API_TOKEN=

# ClickHouse Cloud
CLICKHOUSE_HOST=<your-instance>.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# Dashboard auth: any LITELLM_KEYS secret works as a login.
# Cookies are signed with a key derived from LITELLM_KEYS, so rotating the
# keys also invalidates all dashboard sessions.
DASHBOARD_COOKIE_SECURE=true   # set false for plain-HTTP local dev
